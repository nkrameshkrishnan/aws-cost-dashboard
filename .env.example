# =============================================================================
# AWS Cost Dashboard — ENVIRONMENT TEMPLATE
# =============================================================================
# Copy this file:
#   Development : cp .env.example .env.development
#   Production  : cp .env.example .env.production  (then fill real values)
#
# All variables used anywhere in the stack live here.
# =============================================================================


# =============================================================================
# INFRASTRUCTURE
# =============================================================================
DOCKER_REGISTRY=your-docker-registry.example.com
VERSION=1.0.0


# =============================================================================
# APPLICATION
# =============================================================================
APP_NAME=AWS Cost Dashboard
APP_VERSION=1.0.0
ENVIRONMENT=development          # development | staging | production
DEBUG=true                       # Set false in production
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FILE=/var/log/cost-dashboard/app.log


# =============================================================================
# SECURITY
# Generate keys:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# =============================================================================
SECRET_KEY=dev-secret-key-change-in-production-min32chars
JWT_SECRET_KEY=dev-jwt-secret-key-change-in-production-min32chars
ENCRYPTION_KEY=dev-fernet-key-CHANGE-IN-PRODUCTION==
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7


# =============================================================================
# DATABASE
# Development (Docker Compose): postgresql://postgres:postgres@localhost:5432/aws_cost_dashboard
# Production  (AWS RDS)        : postgresql://user:pass@rds-endpoint.rds.amazonaws.com:5432/dbname
# =============================================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aws_cost_dashboard


# =============================================================================
# REDIS
# Development (Docker Compose): localhost
# Production  (ElastiCache)   : your-cluster.cache.amazonaws.com
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=


# =============================================================================
# CORS — comma-separated list of allowed frontend origins
# Add your GitHub Pages URL here when deploying:
#   CORS_ORIGINS=https://<username>.github.io,http://localhost:5173,http://localhost:3000
# =============================================================================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000


# =============================================================================
# FRONTEND (Vite) — baked into JS bundle at build time
# =============================================================================
# Direct backend (default dev):
#   VITE_API_BASE_URL=http://localhost:8000
# Via LocalStack API Gateway (run localstack-setup.sh to get the URL):
#   VITE_API_BASE_URL=http://localhost.localstack.cloud:4566/restapis/<API_ID>/local/_user_request_
# Production (AWS API Gateway invoke URL set as a GitHub Actions secret):
#   VITE_API_BASE_URL=https://<id>.execute-api.us-east-1.amazonaws.com
VITE_API_BASE_URL=http://localhost:8000
VITE_API_VERSION=v1
VITE_APP_NAME=AWS Cost Dashboard
VITE_APP_VERSION=1.0.0


# =============================================================================
# AWS
# =============================================================================
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1
AWS_PROFILE_CONFIG_PATH=~/.aws/credentials
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=


# =============================================================================
# LOCALSTACK (local AWS emulation for development/testing)
# =============================================================================
# Start LocalStack:
#   docker-compose -f docker-compose.yml -f docker-compose.localstack.yml up -d
# Provision API Gateway + S3 + secrets:
#   ./scripts/localstack-setup.sh
#
# Set AWS_ENDPOINT_URL to redirect all AWS SDK calls to LocalStack.
# Unset or leave blank in staging/production.
# AWS_ENDPOINT_URL=http://localhost.localstack.cloud:4566
LOCALSTACK_ENDPOINT=http://localhost.localstack.cloud:4566
LOCALSTACK_DEBUG=0
LOCALSTACK_PERSISTENCE=1


# =============================================================================
# API
# =============================================================================
API_V1_PREFIX=/api/v1


# =============================================================================
# EXPORT
# =============================================================================
# Production:  your real S3 bucket name (created by Terraform)
# LocalStack:  aws-cost-dashboard-exports  (created by localstack-setup.sh)
EXPORT_S3_BUCKET=
EXPORT_LOCAL_PATH=/tmp/exports


# =============================================================================
# MICROSOFT TEAMS (optional)
# =============================================================================
TEAMS_WEBHOOK_URL=


# =============================================================================
# CACHE TTL (seconds)
# =============================================================================
CACHE_TTL_CURRENT_MONTH=300
CACHE_TTL_HISTORICAL=86400
CACHE_TTL_FORECAST=3600
CACHE_TTL_SERVICE_BREAKDOWN=900
CACHE_TTL_BUDGET_STATUS=600
CACHE_TTL_AUDIT_RESULTS=1800


# =============================================================================
# PERFORMANCE
# =============================================================================
WORKERS=4
REQUEST_TIMEOUT=120


# =============================================================================
# FEATURE FLAGS
# =============================================================================
FEATURE_RIGHTSIZING=true
FEATURE_BUDGETS=true
FEATURE_FINOPS_AUDIT=true
FEATURE_ANALYTICS=true
FEATURE_AUTOMATION=true
FEATURE_UNIT_COSTS=true


# =============================================================================
# DOCS / SWAGGER
# =============================================================================
ENABLE_DOCS=true
ENABLE_TEST_ENDPOINTS=false
