# ============================================================================
# AWS Cost Dashboard Frontend - Environment Configuration
# ============================================================================
# Copy this file to .env for local development
# For production builds, these are embedded at build time

# ============================================================================
# API Configuration
# ============================================================================
# Backend API base URL
VITE_API_BASE_URL=http://localhost:8000

# API version
VITE_API_VERSION=v1

# Full API endpoint (auto-constructed if not set)
# VITE_API_ENDPOINT=http://localhost:8000/api/v1

# ============================================================================
# Application Settings
# ============================================================================
VITE_APP_NAME=AWS Cost Dashboard
VITE_APP_VERSION=1.0.0

# ============================================================================
# Production Configuration
# ============================================================================
# For production deployment, use your actual domain:
# VITE_API_BASE_URL=https://api.your-domain.com
# VITE_API_VERSION=v1

# Example for AWS deployment behind ALB:
# VITE_API_BASE_URL=https://cost-dashboard-api.your-domain.com

# Example for same-domain deployment (Nginx proxy):
# VITE_API_BASE_URL=https://your-domain.com

# ============================================================================
# Feature Flags (optional)
# ============================================================================
# Enable/disable features at build time
# VITE_ENABLE_RIGHTSIZING=true
# VITE_ENABLE_BUDGETS=true
# VITE_ENABLE_FINOPS_AUDIT=true
# VITE_ENABLE_ANALYTICS=true
# VITE_ENABLE_AUTOMATION=true

# ============================================================================
# Development Settings
# ============================================================================
# Enable debug mode (shows additional console logs)
# VITE_DEBUG=false

# Enable mock data for development (if implemented)
# VITE_USE_MOCK_DATA=false

# ============================================================================
# Analytics & Monitoring (optional)
# ============================================================================
# Google Analytics tracking ID
# VITE_GA_TRACKING_ID=

# Sentry DSN for error tracking
# VITE_SENTRY_DSN=
