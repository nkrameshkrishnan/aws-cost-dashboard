# ============================================================================
# AWS Cost Dashboard Backend - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!
# For production, use AWS Secrets Manager or environment variables

# ============================================================================
# Application Settings
# ============================================================================
APP_NAME=AWS Cost Dashboard
APP_VERSION=1.0.0
ENVIRONMENT=development  # Options: development, staging, production
DEBUG=True  # IMPORTANT: Set to False in production
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ============================================================================
# Security Keys
# ============================================================================
# CRITICAL: Generate strong random keys for production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-this-in-production
JWT_SECRET_KEY=your-jwt-secret-change-this-in-production

# Encryption key for AWS credentials storage
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=2nF7qR9xK3mP8vL5tJ4wH6eC1bN0aY3sD7fG2hK9mQ8=

# ============================================================================
# API Configuration
# ============================================================================
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000

# CORS - Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Production example with GitHub Pages and API Gateway:
# CORS_ORIGINS=https://your-username.github.io,https://api-id.execute-api.region.amazonaws.com

# Production example with custom domain:
# CORS_ORIGINS=https://your-username.github.io,https://dashboard.your-domain.com

# ============================================================================
# Database Configuration (PostgreSQL)
# ============================================================================
# Development (Docker Compose)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aws_cost_dashboard

# Production (AWS RDS example)
# DATABASE_URL=postgresql://username:password@your-rds-endpoint.rds.amazonaws.com:5432/aws_cost_dashboard

# ============================================================================
# Redis Cache Configuration
# ============================================================================
# Development (Docker Compose)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Production (AWS ElastiCache example)
# REDIS_HOST=your-elasticache.cache.amazonaws.com
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=your-redis-password
# REDIS_SSL=True

# ============================================================================
# AWS Configuration
# ============================================================================
AWS_DEFAULT_REGION=us-east-1

# AWS credentials method (choose one):
# 1. Profile-based (recommended for development)
AWS_PROFILE_CONFIG_PATH=~/.aws/credentials

# 2. IAM Role (recommended for production on EC2/ECS)
# (No configuration needed - automatically detected)

# 3. Environment variables (alternative for production)
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key

# ============================================================================
# Export Settings
# ============================================================================
EXPORT_S3_BUCKET=cost-dashboard-reports
EXPORT_LOCAL_PATH=/tmp/exports

# ============================================================================
# Microsoft Teams Integration
# ============================================================================
# Teams webhook URL for notifications (optional)
TEAMS_WEBHOOK_URL=

# Multiple webhooks can be configured in the database via UI

# ============================================================================
# JWT Authentication
# ============================================================================
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_FILE=/var/log/cost-dashboard/app.log

# ============================================================================
# Cache TTL Settings (in seconds)
# ============================================================================
# These override defaults in cache_config.py
CACHE_TTL_CURRENT_MONTH=300       # 5 minutes
CACHE_TTL_HISTORICAL=86400        # 24 hours
CACHE_TTL_FORECAST=3600           # 1 hour
CACHE_TTL_SERVICE_BREAKDOWN=900   # 15 minutes
CACHE_TTL_BUDGET_STATUS=600       # 10 minutes
CACHE_TTL_AUDIT_RESULTS=1800      # 30 minutes

# ============================================================================
# Performance Settings
# ============================================================================
# Number of Gunicorn workers (production)
# Formula: (2 x CPU cores) + 1
WORKERS=4

# Request timeout (seconds)
REQUEST_TIMEOUT=120

# ============================================================================
# Feature Flags
# ============================================================================
FEATURE_RIGHTSIZING=True
FEATURE_BUDGETS=True
FEATURE_FINOPS_AUDIT=True
FEATURE_ANALYTICS=True
FEATURE_AUTOMATION=True
FEATURE_UNIT_COSTS=True

# ============================================================================
# Development Settings (do not use in production)
# ============================================================================
# Enable Swagger UI documentation
ENABLE_DOCS=True  # Set to False in production

# Enable test endpoints
ENABLE_TEST_ENDPOINTS=False  # NEVER enable in production
