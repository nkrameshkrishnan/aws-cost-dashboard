# ============================================================================
# AWS Cost Dashboard — Terraform Variables
# ============================================================================
# Copy this file to terraform.tfvars and fill in your values.
# DO NOT commit terraform.tfvars to version control.
#
# Architecture note:
#   The frontend is hosted on GitHub Pages (static, free).
#   Only the backend (FastAPI) runs on ECS Fargate.
#   API Gateway acts as the public HTTPS entry point.
# ============================================================================

# AWS region
aws_region = "us-east-1"

# Environment
environment = "production"

# Project name (used in resource naming)
project_name = "awscost"

# VPC CIDR block
vpc_cidr = "10.0.0.0/16"

# ============================================================================
# Database (RDS PostgreSQL)
# ============================================================================

db_instance_class    = "db.t3.medium"
db_allocated_storage = 100

# Master credentials — use strong random values
# Generate: openssl rand -base64 24
db_username = "dbadmin"
db_password = "REPLACE_WITH_STRONG_PASSWORD"

# ============================================================================
# Cache (ElastiCache Redis)
# ============================================================================

redis_node_type       = "cache.t3.medium"
redis_num_cache_nodes = 2   # 2+ for Multi-AZ in production; 1 is fine for dev

# ============================================================================
# Application Secrets
# ============================================================================

# Generate with: openssl rand -hex 32
secret_key     = "REPLACE_WITH_64_CHAR_HEX_STRING"
jwt_secret_key = "REPLACE_WITH_64_CHAR_HEX_STRING"

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
encryption_key = "REPLACE_WITH_44_CHAR_FERNET_KEY="

# ============================================================================
# ECS Fargate — Backend only
# (The frontend Docker image exists but is served from GitHub Pages, not ECS)
# ============================================================================

# Backend image in your registry
backend_image = "ghcr.io/your-org/aws-cost-dashboard-backend:latest"
# AWS ECR example:
# backend_image = "123456789012.dkr.ecr.us-east-1.amazonaws.com/awscost-backend:latest"

backend_task_cpu    = 1024  # 1 vCPU
backend_task_memory = 2048  # 2 GB

ecs_desired_count = 2
ecs_min_capacity  = 2
ecs_max_capacity  = 10

# ============================================================================
# API Gateway + CORS
# ============================================================================
#
# IMPORTANT: The GitHub Pages URL MUST be listed here so the browser doesn't
# block cross-origin requests to the API.
#
# After `terraform apply`, the api_gateway_url output gives you the URL to set
# as VITE_API_BASE_URL in .env.production before building the frontend.
# ============================================================================

cors_allowed_origins = [
  "https://YOUR-GITHUB-USERNAME.github.io",  # ← replace with your GitHub username
  "http://localhost:5173",                    # local Vite dev server
  "http://localhost:3000",                    # alternative local dev
]

# Optional: custom domain for the API Gateway (e.g. api.example.com)
# Requires a valid ACM certificate in the same region.
custom_domain_name = ""
# custom_domain_name = "api.your-domain.com"

# ============================================================================
# Optional: TLS certificate for the internal ALB
# ============================================================================

certificate_arn = ""
# certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/abc123..."

# ============================================================================
# Optional: S3 bucket for report uploads
# ============================================================================

s3_bucket_arn = ""
# s3_bucket_arn = "arn:aws:s3:::your-reports-bucket"
