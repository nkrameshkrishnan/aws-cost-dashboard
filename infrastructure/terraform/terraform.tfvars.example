# ============================================================================
# AWS Cost Dashboard - Terraform Variables Example
# ============================================================================
# Copy this file to terraform.tfvars and fill in your values
# DO NOT commit terraform.tfvars to version control!

# AWS Region
aws_region = "us-east-1"

# Environment (development, staging, production)
environment = "production"

# Project name (used for resource naming)
project_name = "awscost"

# VPC CIDR block
vpc_cidr = "10.0.0.0/16"

# ============================================================================
# Database Configuration
# ============================================================================

# RDS instance class (db.t3.micro, db.t3.small, db.t3.medium, db.t3.large)
db_instance_class = "db.t3.medium"

# RDS allocated storage in GB
db_allocated_storage = 100

# Database master username
db_username = "dbadmin"

# Database master password
# IMPORTANT: Use a strong random password
# Generate with: openssl rand -base64 32
db_password = "REPLACE_WITH_STRONG_PASSWORD"

# ============================================================================
# ElastiCache Configuration
# ============================================================================

# Redis node type (cache.t3.micro, cache.t3.small, cache.t3.medium)
redis_node_type = "cache.t3.medium"

# Number of cache nodes (2 or more for Multi-AZ)
redis_num_cache_nodes = 2

# ============================================================================
# ECS Configuration
# ============================================================================

# CPU units for ECS task (256, 512, 1024, 2048, 4096)
ecs_task_cpu = "1024"

# Memory for ECS task in MB (512, 1024, 2048, 4096, 8192)
ecs_task_memory = "2048"

# Desired number of ECS tasks
ecs_desired_count = 2

# Docker images (replace with your registry)
backend_image = "your-registry/awscost-backend:latest"
frontend_image = "your-registry/awscost-frontend:latest"

# Example for GitHub Container Registry:
# backend_image = "ghcr.io/your-org/aws-cost-dashboard-backend:latest"
# frontend_image = "ghcr.io/your-org/aws-cost-dashboard-frontend:latest"

# Example for AWS ECR:
# backend_image = "123456789012.dkr.ecr.us-east-1.amazonaws.com/awscost-backend:latest"
# frontend_image = "123456789012.dkr.ecr.us-east-1.amazonaws.com/awscost-frontend:latest"

# ============================================================================
# Optional: Custom Domain & SSL
# ============================================================================

# Domain name for the application (optional)
# Leave empty to use ALB DNS name
domain_name = ""

# ACM certificate ARN for HTTPS (optional)
# Leave empty to use HTTP only
certificate_arn = ""

# Example:
# domain_name = "cost-dashboard.your-domain.com"
# certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/abc123..."

# ============================================================================
# API Gateway Configuration
# ============================================================================

# CORS allowed origins (must include GitHub Pages URL and any custom domains)
# IMPORTANT: Update with your actual GitHub Pages URL
cors_allowed_origins = [
  "https://your-username.github.io",  # Replace with your GitHub username
  "http://localhost:5173",            # Local development
  "http://localhost:3000",            # Alternative local dev
]

# Example for custom domain:
# cors_allowed_origins = [
#   "https://your-username.github.io",
#   "https://dashboard.your-domain.com",
#   "http://localhost:5173",
# ]

# Custom domain for API Gateway (optional)
# If specified, must have a valid ACM certificate ARN above
custom_domain_name = ""

# Example:
# custom_domain_name = "api.your-domain.com"
