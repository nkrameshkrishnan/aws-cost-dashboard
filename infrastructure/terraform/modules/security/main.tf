# VPC Link Security Group (for API Gateway)
resource "aws_security_group" "vpc_link" {
  name_prefix = "${var.name_prefix}-vpc-link-"
  description = "Security group for API Gateway VPC Link"
  vpc_id      = var.vpc_id

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
    description = "Allow all outbound"
  }

  tags = merge(
    var.tags,
    {
      Name = "${var.name_prefix}-vpc-link-sg"
    }
  )

  lifecycle {
    create_before_destroy = true
  }
}

# Security Group Rule - ALB allows traffic from VPC Link
resource "aws_security_group_rule" "alb_from_vpc_link" {
  type                     = "ingress"
  from_port                = 80
  to_port                  = 80
  protocol                 = "tcp"
  source_security_group_id = aws_security_group.vpc_link.id
  security_group_id        = aws_security_group.alb.id
  description              = "HTTP from VPC Link"
}
